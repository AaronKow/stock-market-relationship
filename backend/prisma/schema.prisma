generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum RelationshipType {
  PEER
  SUPPLIER
  CUSTOMER
  COMPETITOR
  PARTNER
  MACRO
}

enum Sentiment {
  POSITIVE
  NEUTRAL
  NEGATIVE
}

enum SessionType {
  PRE_MARKET
  IN_MARKET
  POST_MARKET
}

enum SignalType {
  EARNINGS
  NEWS
  PRICE_ACTION
  ANALYST
  INSIDER
  TECHNICAL
  MACRO
}

enum IngestionStatus {
  STARTED
  SUCCEEDED
  FAILED
}

model User {
  id            String         @id @default(uuid())
  email         String         @unique
  name          String?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  watchlists    Watchlist[]
  relationships Relationship[] @relation("RelationshipCreator")
}

model Company {
  id                  String                 @id @default(uuid())
  ticker              String                 @unique
  name                String
  sector              String?
  industry            String?
  exchange            String?
  country             String?
  createdAt           DateTime               @default(now())
  updatedAt           DateTime               @updatedAt
  earningsEvents      EarningsEvent[]
  sourceRelationships Relationship[]         @relation("RelationshipSource")
  targetRelationships Relationship[]         @relation("RelationshipTarget")
  signalEvents        SignalEvent[]
  scoreSnapshots      CompanyScoreSnapshot[]
  watchlistItems      WatchlistItem[]

  @@index([name])
  @@index([sector, industry])
}

model EarningsEvent {
  id               String        @id @default(uuid())
  companyId        String
  eventDate        DateTime
  sessionType      SessionType
  fiscalQuarter    Int?
  fiscalYear       Int?
  estimatedEps     Decimal?      @db.Decimal(8, 4)
  actualEps        Decimal?      @db.Decimal(8, 4)
  estimatedRevenue Decimal?      @db.Decimal(18, 2)
  actualRevenue    Decimal?      @db.Decimal(18, 2)
  notes            String?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
  company          Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  signalEvents     SignalEvent[]

  @@unique([companyId, fiscalYear, fiscalQuarter])
  @@index([companyId, eventDate])
  @@index([eventDate])
}

model Relationship {
  id               String           @id @default(uuid())
  sourceCompanyId  String
  targetCompanyId  String
  relationshipType RelationshipType
  strength         Float?
  confidence       Float?
  rationale        String?
  createdByUserId  String?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  sourceCompany    Company          @relation("RelationshipSource", fields: [sourceCompanyId], references: [id], onDelete: Cascade)
  targetCompany    Company          @relation("RelationshipTarget", fields: [targetCompanyId], references: [id], onDelete: Cascade)
  createdBy        User?            @relation("RelationshipCreator", fields: [createdByUserId], references: [id], onDelete: SetNull)
  signalEvents     SignalEvent[]

  @@unique([sourceCompanyId, targetCompanyId, relationshipType])
  @@index([sourceCompanyId, relationshipType])
  @@index([targetCompanyId, relationshipType])
}

model SignalEvent {
  id              String         @id @default(uuid())
  companyId       String
  relationshipId  String?
  earningsEventId String?
  signalType      SignalType
  sentiment       Sentiment
  occurredAt      DateTime
  headline        String?
  description     String?
  source          String?
  sourceUrl       String?
  confidence      Float?
  metadata        Json?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  company         Company        @relation(fields: [companyId], references: [id], onDelete: Cascade)
  relationship    Relationship?  @relation(fields: [relationshipId], references: [id], onDelete: SetNull)
  earningsEvent   EarningsEvent? @relation(fields: [earningsEventId], references: [id], onDelete: SetNull)

  @@index([companyId, occurredAt])
  @@index([signalType, occurredAt])
  @@index([relationshipId])
  @@index([earningsEventId])
  @@index([sentiment, occurredAt])
}

model CompanyScoreSnapshot {
  id                String   @id @default(uuid())
  companyId         String
  snapshotDate      DateTime
  relationshipScore Float
  signalScore       Float
  earningsScore     Float?
  totalScore        Float
  scoreBreakdown    Json?
  createdAt         DateTime @default(now())
  company           Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([companyId, snapshotDate])
  @@index([snapshotDate])
  @@index([companyId, totalScore])
}

model Watchlist {
  id          String          @id @default(uuid())
  userId      String
  name        String
  description String?
  isDefault   Boolean         @default(false)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  user        User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  items       WatchlistItem[]

  @@unique([userId, name])
  @@index([userId, isDefault])
}

model WatchlistItem {
  id          String    @id @default(uuid())
  watchlistId String
  companyId   String
  notes       String?
  addedAt     DateTime  @default(now())
  watchlist   Watchlist @relation(fields: [watchlistId], references: [id], onDelete: Cascade)
  company     Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([watchlistId, companyId])
  @@index([companyId])
}

model IngestionLog {
  id               String          @id @default(uuid())
  source           String
  entityType       String
  status           IngestionStatus
  startedAt        DateTime
  finishedAt       DateTime?
  recordsProcessed Int             @default(0)
  recordsFailed    Int             @default(0)
  checksum         String?
  errorMessage     String?
  metadata         Json?
  createdAt        DateTime        @default(now())

  @@index([source, entityType, startedAt])
  @@index([status, startedAt])
}
