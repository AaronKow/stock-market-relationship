{
  "name": "@stock-market-relationship/backend",
  "private": true,
  "version": "0.1.0",
  "main": "src/server.js",
  "scripts": {
    "dev": "nodemon src/server.js",
    "start": "npm run start:with-migrate",
    "start:server": "node src/server.js",
    "start:with-migrate": "npm run prisma:migrate:deploy && npm run start:server",
    "build": "echo 'No build step required for backend'",
    "prisma:generate": "prisma generate --schema prisma/schema.prisma",
    "prisma:migrate:dev": "prisma migrate dev --schema prisma/schema.prisma",
    "prisma:migrate:deploy": "prisma migrate deploy --schema prisma/schema.prisma",
    "db:seed": "prisma db seed --schema prisma/schema.prisma",
    "scores:recompute": "node src/scripts/recomputeScoreSnapshots.js",
    "ingest:earnings": "node ../scripts/ingestion/earningsIngestion.js",
    "ingest:company-metadata": "node ../scripts/ingestion/companyMetadataIngestion.js",
    "ingest:relationships": "node ../scripts/ingestion/relationshipsIngestion.js",
    "ingest:signals": "node ../scripts/ingestion/signalsIngestion.js",
    "render:postdeploy": "node scripts/render-postdeploy.js"
  },
  "dependencies": {
    "@prisma/client": "^6.16.3",
    "cors": "^2.8.5",
    "dotenv": "^17.2.3",
    "express": "^5.1.0",
    "node-cron": "^4.2.1"
  },
  "devDependencies": {
    "nodemon": "^3.1.10",
    "prisma": "^6.16.3"
  },
  "prisma": {
    "seed": "node prisma/seed.js"
  }
}
