{
  "name": "stock-market-relationship",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "frontend",
    "backend",
    "shared"
  ],
  "scripts": {
    "dev": "npm run dev:frontend & npm run dev:backend",
    "dev:frontend": "npm --workspace frontend run dev",
    "dev:backend": "npm --workspace backend run dev",
    "build": "npm run build --workspaces",
    "db:seed": "npm --workspace backend run db:seed",
    "ingest:earnings": "node scripts/ingestion/earningsIngestion.js",
    "ingest:relationships": "node scripts/ingestion/relationshipsIngestion.js",
    "ingest:signals": "node scripts/ingestion/signalsIngestion.js"
  }
}
