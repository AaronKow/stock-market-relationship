# Root-level reference values for local development.
# Service-specific variables are defined in frontend/.env.example and backend/.env.example.

VITE_API_BASE_URL=http://localhost:4000/api
PORT=4000
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/stock_relationship?schema=public
CLIENT_URL=http://localhost:5173
NODE_ENV=development

# Optional ingestion configuration
CRON_INGEST_COMPANY_METADATA=15 */6 * * *
INGESTION_MAX_RETRIES=2
INGESTION_MAX_PAGES=25
EARNINGS_JSON_PATH=backend/src/ingestion/samples/earnings.sample.json
COMPANY_METADATA_JSON_PATH=backend/src/ingestion/samples/companyMetadata.sample.json
RELATIONSHIPS_JSON_PATH=backend/src/ingestion/samples/relationships.sample.json
SIGNALS_JSON_PATH=backend/src/ingestion/samples/signals.sample.json

# Optional provider keys (paid providers remain disabled if unset)
FMP_API_KEY=
PREMIUM_NEWS_API_KEY=
SEC_API_USER_AGENT=
